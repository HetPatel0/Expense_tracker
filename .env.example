# Existing app variables such as DATABASE_URL stay in your local .env.

# AI setup
# Paste an OpenRouter API key here to use the default free model route.
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openrouter/free

# Used for OpenRouter request headers and frontend links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
