# Existing app variables such as DATABASE_URL stay in your local .env.

# AI setup
# Paste an OpenRouter API key here to use the default free Mistral model.
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
AI_TIMEOUT_MS=8000
AI_RATE_LIMIT_COOLDOWN_MS=600000

# Used for OpenRouter request headers and frontend links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
